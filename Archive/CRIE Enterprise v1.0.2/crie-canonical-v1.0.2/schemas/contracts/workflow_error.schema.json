{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "crie/contracts/workflow_error",
  "title": "Workflow Error",
  "description": "Structured error every workflow returns (¬ß19). errorType classifies handling: Recoverable‚Üíretry, Business‚Üíhuman review, Fatal‚Üístop, Unexpected‚Üílog+alert+stop.",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "module", "node", "errorType"],
  "properties": {
    "status":    { "type": "string", "const": "FAILED" },
    "module":    { "type": "string" },
