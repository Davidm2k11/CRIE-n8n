# CRIE Environment Template
# --------------------------------------------------------------------------
# Copy to `.env` and fill in real values. NEVER commit `.env` (see .gitignore).
# Sensitive values SHALL never appear in this example file (§682).
# All environment-specific values use environment variables (§169).
# Secrets live only in allowed locations — never inside workflows (§321–324, §608).
# --------------------------------------------------------------------------

# ── Supabase (PostgreSQL + pgvector) ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── LLM Provider (configurable; OpenAI is the v1 default, §316–320) ──
OPENAI_API_KEY=

# ── Azure Document Intelligence (OCR) ──
AZURE_ENDPOINT=
AZURE_KEY=

# ── n8n workspace ──
N8N_ENCRYPTION_KEY=
N8N_HOST=
N8N_PORT=

# --------------------------------------------------------------------------
# Provider adapters (§316–320) are configured in configuration/providers.yaml.
# This template lists only the secret/endpoint values that must be supplied
# per-environment. See docs/deployment and §682 for the full guide.
# --------------------------------------------------------------------------
